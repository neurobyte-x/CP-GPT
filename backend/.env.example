# CP Path Builder — Backend Environment Variables

# ─── Application Settings ───────────────────────────────────────
APP_NAME=CP Path Builder
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production
HOST=0.0.0.0
PORT=8000

# ─── CORS Configuration ──────────────────────────────────────────
# Add your Vercel frontend URL here
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://your-project.vercel.app

# ─── Database ────────────────────────────────────────────────────
# PostgreSQL with asyncpg driver
# For Neon DB: postgresql+asyncpg://user:password@ep-xxx.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_ECHO=false
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_SSL=true

# ─── Redis / Caching ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# ─── Authentication ─────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Codeforces API ──────────────────────────────────────────────
CF_API_BASE_URL=https://codeforces.com/api
CF_API_KEY=
CF_API_SECRET=
CF_SYNC_INTERVAL_HOURS=6
CF_REQUEST_DELAY_SECONDS=2.0

# ─── AI / LLM ───────────────────────────────────────────────────
# Supported: gemini-2.5-flash, gpt-4o-mini, claude-3.5-sonnet, etc.
GEMINI_API_KEY=your-gemini-api-key
LLM_MODEL=gemini-2.5-flash
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.3
COACHING_ENABLED=true

# ─── Background Tasks ───────────────────────────────────────────
SYNC_ON_STARTUP=false
TASK_CONCURRENCY=4

# ─── Practice Path Configuration ────────────────────────────────
DEFAULT_PATH_SIZE=30
MAX_PATH_SIZE=100
RATING_STEP=100
MIN_PROBLEM_RATING=800
MAX_PROBLEM_RATING=3500
